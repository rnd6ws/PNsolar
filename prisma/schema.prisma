generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===== NHÂN VIÊN (Employee) =====
model DSNV {
  ID            String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_NV         String  @unique
  USER_NAME     String  @unique
  PASSWORD      String // bcrypt hash
  HINH_CA_NHAN  String?
  HO_TEN        String
  CHUC_VU       String
  PHONG_BAN     String? // Add PHONG_BAN column
  SO_DIEN_THOAI String?
  EMAIL         String?
  DIA_CHI       String?
  ROLE          ROLE    @default(STAFF)
  IS_ACTIVE     Boolean @default(true)

  // Soft Delete
  DELETED_AT DateTime?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  AUDIT_LOGS  AUDIT_LOG[]
  PHAN_QUYEN  PHAN_QUYEN[]

  @@index([IS_ACTIVE, ROLE])
  @@fulltext([HO_TEN, USER_NAME, MA_NV])
  @@map("DSNV")
}

enum ROLE {
  ADMIN
  MANAGER
  STAFF
}

// ===== DANH MỤC HÀNG HÓA (Product Catalog) =====
model DMHH {
  ID          String  @id @default(auto()) @map("_id") @db.ObjectId
  ID_HH       String  @unique
  PHAN_LOAI   String
  DONG_HANG   String
  TEN         String
  MODEL       String
  MO_TA       String?
  DON_VI_TINH String
  HINH_ANH    String?
  XUAT_XU     String?
  BAO_HANH    String?

  // Soft Delete
  DELETED_AT DateTime?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([DELETED_AT, PHAN_LOAI, DONG_HANG])
  @@fulltext([TEN, MODEL, ID_HH])
  @@map("DMHH")
}

// ===== PHÂN LOẠI HÀNG HÓA =====
model PHANLOAI_HH {
  ID            String    @id @default(auto()) @map("_id") @db.ObjectId
  MA_PHAN_LOAI  String    @unique
  TEN_PHAN_LOAI String
  DVT_NHOM      String
  NHOM          String?

  DELETED_AT    DateTime?
  CREATED_AT    DateTime  @default(now())
  UPDATED_AT    DateTime  @updatedAt

  @@map("PHANLOAI_HH")
}

// ===== NHÓM HÀNG HÓA =====
model NHOM_HH {
  ID         String    @id @default(auto()) @map("_id") @db.ObjectId
  MA_NHOM    String    @unique
  TEN_NHOM   String

  DELETED_AT DateTime?
  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("NHOM_HH")
}

// ===== PHÂN QUYỀN (Permissions) =====
model PHAN_QUYEN {
  ID         String   @id @default(auto()) @map("_id") @db.ObjectId
  NV_ID      String   @db.ObjectId
  NV         DSNV     @relation(fields: [NV_ID], references: [ID])
  MODULE     String   // e.g. "nhan-vien", "hang-hoa", "settings"
  CAN_VIEW   Boolean  @default(false)
  CAN_ADD    Boolean  @default(false)
  CAN_EDIT   Boolean  @default(false)
  CAN_DELETE Boolean  @default(false)
  CAN_MANAGE Boolean  @default(false) // Toàn quyền


  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@unique([NV_ID, MODULE])
  @@index([NV_ID])
  @@map("PHAN_QUYEN")
}

// ===== AUDIT LOG =====
model AUDIT_LOG {
  ID           String   @id @default(auto()) @map("_id") @db.ObjectId
  ACTION       String
  USER_ID      String   @db.ObjectId
  USER         DSNV     @relation(fields: [USER_ID], references: [ID])
  USER_NAME    String? // Denormalize
  TARGET_MODEL String?
  TARGET_ID    String?
  DETAILS      String
  OLD_VALUE    Json?
  NEW_VALUE    Json?
  CREATED_AT   DateTime @default(now())

  @@index([USER_ID, CREATED_AT(sort: Desc)])
  @@index([TARGET_MODEL, TARGET_ID, CREATED_AT(sort: Desc)])
  @@index([CREATED_AT])
  @@map("AUDIT_LOGS")
}

// ===== TỪ ĐIỂN CHỨC VỤ =====
model CD_CHUCVU {
  ID         String    @id @default(auto()) @map("_id") @db.ObjectId
  CHUC_VU    String    @unique
  GHI_CHU    String?
  IS_ACTIVE  Boolean   @default(true)
  DELETED_AT DateTime?
  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("CD_CHUCVU")
}

// ===== TỪ ĐIỂN PHÒNG BAN =====
model CD_PHONGBAN {
  ID         String    @id @default(auto()) @map("_id") @db.ObjectId
  PHONG_BAN  String    @unique
  GHI_CHU    String?
  IS_ACTIVE  Boolean   @default(true)
  DELETED_AT DateTime?
  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("CD_PHONGBAN")
}
