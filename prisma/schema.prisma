generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===== NHÂN VIÊN (Employee) =====
model DSNV {
  ID            String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_NV         String  @unique
  USER_NAME     String  @unique
  PASSWORD      String // bcrypt hash
  HINH_CA_NHAN  String?
  HO_TEN        String
  CHUC_VU       String
  PHONG_BAN     String? // Add PHONG_BAN column
  SO_DIEN_THOAI String?
  EMAIL         String?
  DIA_CHI       String?
  ROLE          ROLE    @default(STAFF)
  IS_ACTIVE     Boolean @default(true)


  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  AUDIT_LOGS AUDIT_LOG[]
  PHAN_QUYEN PHAN_QUYEN[]

  @@index([IS_ACTIVE, ROLE])
  @@fulltext([HO_TEN, USER_NAME, MA_NV])
  @@map("DSNV")
}

enum ROLE {
  ADMIN
  MANAGER
  STAFF
}

// ===== DANH MỤC HÀNG HÓA (Product Catalog) =====
model DMHH {
  ID          String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_HH       String  @unique
  NHOM_HH     String?
  PHAN_LOAI   String
  DONG_HANG   String
  TEN_HH      String
  MODEL       String
  MO_TA       String?
  DON_VI_TINH String
  HINH_ANH    String?
  XUAT_XU     String?
  BAO_HANH    String?
  HIEU_LUC    Boolean @default(true)


  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([NHOM_HH, PHAN_LOAI, DONG_HANG])
  @@fulltext([TEN_HH, MODEL, MA_HH])
  @@map("DMHH")
}

// ===== PHÂN LOẠI HÀNG HÓA =====
model PHANLOAI_HH {
  ID            String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_PHAN_LOAI  String  @unique
  TEN_PHAN_LOAI String
  DVT_NHOM      String
  NHOM          String?

  DONG_HHS DONG_HH[] // Relation to DONG_HH


  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("PHANLOAI_HH")
}

// ===== DÒNG HÀNG HÓA =====
model DONG_HH {
  ID            String      @id @default(auto()) @map("_id") @db.ObjectId
  PHAN_LOAI_ID  String      @db.ObjectId
  PHAN_LOAI     PHANLOAI_HH @relation(fields: [PHAN_LOAI_ID], references: [ID])
  MA_DONG_HANG  String      @unique // ID dòng hàng
  TEN_DONG_HANG String // Dòng hàng
  TIEN_TO       String? // Tiền tố tên
  HANG          String? // Hãng
  XUAT_XU       String? // Xuất xứ
  DVT           String? // ĐVT


  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@index([PHAN_LOAI_ID])
  @@map("DONG_HH")
}

// ===== NHÓM HÀNG HÓA =====
model NHOM_HH {
  ID       String @id @default(auto()) @map("_id") @db.ObjectId
  MA_NHOM  String @unique
  TEN_NHOM String


  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("NHOM_HH")
}

// ===== PHÂN QUYỀN (Permissions) =====
model PHAN_QUYEN {
  ID         String  @id @default(auto()) @map("_id") @db.ObjectId
  NV_ID      String  @db.ObjectId
  NV         DSNV    @relation(fields: [NV_ID], references: [ID])
  MODULE     String // e.g. "nhan-vien", "hang-hoa", "settings"
  CAN_VIEW   Boolean @default(false)
  CAN_ADD    Boolean @default(false)
  CAN_EDIT   Boolean @default(false)
  CAN_DELETE Boolean @default(false)
  CAN_MANAGE Boolean @default(false) // Toàn quyền

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@unique([NV_ID, MODULE])
  @@index([NV_ID])
  @@map("PHAN_QUYEN")
}

// ===== AUDIT LOG =====
model AUDIT_LOG {
  ID           String   @id @default(auto()) @map("_id") @db.ObjectId
  ACTION       String
  USER_ID      String   @db.ObjectId
  USER         DSNV     @relation(fields: [USER_ID], references: [ID])
  USER_NAME    String? // Denormalize
  TARGET_MODEL String?
  TARGET_ID    String?
  DETAILS      String
  OLD_VALUE    Json?
  NEW_VALUE    Json?
  CREATED_AT   DateTime @default(now())

  @@index([USER_ID, CREATED_AT(sort: Desc)])
  @@index([TARGET_MODEL, TARGET_ID, CREATED_AT(sort: Desc)])
  @@index([CREATED_AT])
  @@map("AUDIT_LOGS")
}

// ===== TỪ ĐIỂN CHỨC VỤ =====
model CD_CHUCVU {
  ID         String    @id @default(auto()) @map("_id") @db.ObjectId
  CHUC_VU    String    @unique
  GHI_CHU    String?
  IS_ACTIVE  Boolean   @default(true)

  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("CD_CHUCVU")
}

// ===== TỪ ĐIỂN PHÒNG BAN =====
model CD_PHONGBAN {
  ID         String    @id @default(auto()) @map("_id") @db.ObjectId
  PHONG_BAN  String    @unique
  GHI_CHU    String?
  IS_ACTIVE  Boolean   @default(true)

  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@map("CD_PHONGBAN")
}

// ===== PHÂN LOẠI KHÁCH HÀNG =====
model PHANLOAI_KH {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  PL_KH String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("PHANLOAI_KH")
}

// ===== NGUỒN KHÁCH HÀNG =====
model NGUON_KH {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  NGUON String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NGUON_KH")
}

// ===== NHÓM KHÁCH HÀNG =====
model NHOM_KH {
  ID   String @id @default(auto()) @map("_id") @db.ObjectId
  NHOM String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NHOM_KH")
}

// ===== KHÁCH HÀNG TỰ NHIÊN =====
model KHTN {
  ID               String    @id @default(auto()) @map("_id") @db.ObjectId
  NHOM_KH          String?
  NGAY_GHI_NHAN    DateTime?
  TEN_KH           String
  TEN_VT           String?
  HINH_ANH         String?
  DIEN_THOAI       String?
  EMAIL            String?
  MST              String?
  NGAY_THANH_LAP   DateTime?
  DIA_CHI          String?
  NGUON            String?
  NGUOI_GIOI_THIEU String?
  SALES_PT         String?
  PHAN_LOAI        String?
  NV_CS            String?
  LICH_SU          String?
  LY_DO_TU_CHOI    String?
  LAT              Float?
  LONG             Float?

  NGUOI_DAI_DIEN NGUOI_DAI_DIEN[]
  NGUOI_LIENHE   NGUOI_LIENHE[]
  CO_HOI         CO_HOI[]
  KEHOACH_CSKH   KEHOACH_CSKH[]

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([NHOM_KH, PHAN_LOAI])
  @@fulltext([TEN_KH, DIEN_THOAI])
  @@map("KHTN")
}

// ===== NGƯỜI GIỚI THIỆU =====
model NGUOI_GIOI_THIEU {
  ID        String  @id @default(auto()) @map("_id") @db.ObjectId
  TEN_NGT   String
  SO_DT_NGT String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NGUOI_GIOI_THIEU")
}

// ===== NGƯỜI ĐẠI DIỆN =====
model NGUOI_DAI_DIEN {
  ID        String    @id @default(auto()) @map("_id") @db.ObjectId
  ID_KH     String    @db.ObjectId
  KH        KHTN      @relation(fields: [ID_KH], references: [ID], onDelete: Cascade)
  NGUOI_DD  String
  CHUC_VU   String?
  SDT       String?
  EMAIL     String?
  NGAY_SINH DateTime?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([ID_KH])
  @@map("NGUOI_DAI_DIEN")
}

// ===== NGƯỜI LIÊN HỆ =====
model NGUOI_LIENHE {
  ID              String  @id @default(auto()) @map("_id") @db.ObjectId
  ID_KH           String  @db.ObjectId
  KH              KHTN    @relation(fields: [ID_KH], references: [ID], onDelete: Cascade)
  TENNGUOI_LIENHE String
  CHUC_VU         String?
  SDT             String?
  EMAIL           String?
  GHI_CHU         String?
  HIEU_LUC        String  @default("Đang hiệu lực")

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([ID_KH])
  @@map("NGUOI_LIENHE")
}

// ===== GÓI GIÁ (Price Package) =====
model GOI_GIA {
  ID            String    @id @default(auto()) @map("_id") @db.ObjectId
  ID_GOI_GIA    String    @unique
  NGAY_HIEU_LUC DateTime?
  MA_DONG_HANG  String
  GOI_GIA       String
  SL_MIN        Int?
  SL_MAX        Int?

  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@index([MA_DONG_HANG])
  @@map("GOI_GIA")
}

// ===== NHÀ CUNG CẤP (Supplier) =====
model NCC {
  ID                  String    @id @default(auto()) @map("_id") @db.ObjectId
  MA_NCC              String    @unique
  TEN_VIET_TAT        String?
  TEN_NCC             String
  NGAY_GHI_NHAN       DateTime?
  HINH_ANH            String?
  DIEN_THOAI          String?
  EMAIL_CONG_TY       String?
  MST                 String?
  NGAY_THANH_LAP      DateTime?
  DIA_CHI             String?
  NGUOI_DAI_DIEN      String?
  SDT_NGUOI_DAI_DIEN  String?

  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@fulltext([TEN_NCC, MA_NCC, DIEN_THOAI])
  @@map("NCC")
}

// ===== GIÁ NHẬP (Purchase Price) =====
model GIA_NHAP {
  ID             String    @id @default(auto()) @map("_id") @db.ObjectId
  NGAY_HIEU_LUC  DateTime
  MA_NCC         String
  TEN_NCC        String
  MA_HH          String
  TEN_HH         String
  DVT            String
  DON_GIA        Float

  CREATED_AT DateTime  @default(now())
  UPDATED_AT DateTime  @updatedAt

  @@index([MA_NCC, MA_HH])
  @@fulltext([MA_NCC, TEN_NCC, MA_HH, TEN_HH])
  @@map("GIA_NHAP")
}

// ===== LÝ DO TỪ CHỐI =====
model LY_DO_TU_CHOI {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  LY_DO String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("LY_DO_TU_CHOI")
}

// ===== DANH MỤC CƠ HỘI (Service Catalog) =====
model DM_CO_HOI {
  ID         String @id @default(auto()) @map("_id") @db.ObjectId
  NHOM_DV    String // Nhóm dịch vụ
  DICH_VU    String // Tên dịch vụ
  GIA_TRI_TB Float // Giá trị trung bình

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([NHOM_DV])
  @@map("DM_CO_HOI")
}

// ===== CƠ HỘI (Opportunity) =====
model CO_HOI {
  ID              String    @id @default(auto()) @map("_id") @db.ObjectId
  ID_CH           String    @unique // OP-TEN_VT-YYMMDD-001
  NGAY_TAO        DateTime  @default(now())
  ID_KH           String    @db.ObjectId
  KH              KHTN      @relation(fields: [ID_KH], references: [ID])
  NHU_CAU         Json? // Mảng các DM_CO_HOI ID được chọn
  GHI_CHU_NC      String?
  GIA_TRI_DU_KIEN Float?
  NGAY_DK_CHOT    DateTime?
  TINH_TRANG      String    @default("Đang mở")
  NGAY_DONG       DateTime?
  LY_DO           String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([ID_KH])
  @@index([TINH_TRANG])
  @@map("CO_HOI")
}

// ===== LOẠI CHĂM SÓC (Care Type) =====
model LOAI_CHAM_SOC {
  ID      String @id @default(auto()) @map("_id") @db.ObjectId
  LOAI_CS String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("LOAI_CHAM_SOC")
}

// ===== KẾT QUẢ CHĂM SÓC (Care Result) =====
model KET_QUA_CS {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  KQ_CS String @unique
  XL_CS String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("KET_QUA_CS")
}

// ===== KẾ HOẠCH CHĂM SÓC KHÁCH HÀNG =====
model KEHOACH_CSKH {
  ID         String    @id @default(auto()) @map("_id") @db.ObjectId
  ID_KH      String    @db.ObjectId
  KH         KHTN      @relation(fields: [ID_KH], references: [ID])
  ID_LH      String?   // Người liên hệ (NGUOI_LIENHE.ID)
  ID_CH      String?   // Cơ hội (CO_HOI.ID)
  LOAI_CS    String?   // Loại chăm sóc
  TG_TU      DateTime? // Thời gian từ
  TG_DEN     DateTime? // Thời gian đến
  HINH_THUC  String?   // Online / Trực tiếp
  DIA_DIEM   String?
  NGUOI_CS   String?   // Người chăm sóc (DSNV.ID)
  NGAY_CS_TT DateTime? // Ngày chăm sóc thực tế
  HINH_ANH   String?
  FILE       String?
  LINK_BC    String?   // Link báo cáo
  DICH_VU_QT Json?     // Dịch vụ quan tâm (mảng DMHH.ID)
  KQ_CS      String?   // Kết quả
  XL_CS      String?   // Xử lý
  NOI_DUNG_TD String?  // Nội dung trao đổi
  LY_DO_TC   String?   // Lý do từ chối
  GHI_CHU_NC String?   // Ghi chú nội bộ
  TRANG_THAI String    @default("Chờ báo cáo")

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([ID_KH])
  @@index([TRANG_THAI])
  @@map("KEHOACH_CSKH")
}
