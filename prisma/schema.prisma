generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===== NHÂN VIÊN (Employee) =====
model DSNV {
  ID            String       @id @default(auto()) @map("_id") @db.ObjectId
  MA_NV         String       @unique
  USER_NAME     String       @unique
  PASSWORD      String // bcrypt hash
  HINH_CA_NHAN  String?
  HO_TEN        String
  CHUC_VU       String
  CHUC_VU_REL   CD_CHUCVU    @relation(fields: [CHUC_VU], references: [CHUC_VU])
  PHONG_BAN     String?
  PHONG_BAN_REL CD_PHONGBAN? @relation(fields: [PHONG_BAN], references: [PHONG_BAN])
  SO_DIEN_THOAI String?
  EMAIL         String?
  DIA_CHI       String?
  ROLE          ROLE         @default(STAFF)
  IS_ACTIVE     Boolean      @default(true)

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  AUDIT_LOGS AUDIT_LOG[]
  PHAN_QUYEN PHAN_QUYEN[]

  KHTN_SALES_PT KHTN[]         @relation("SALES_PT")
  KHTN_NV_CS    KHTN[]         @relation("NV_CS")
  KEHOACH_CSKH  KEHOACH_CSKH[] @relation("NGUOI_CS")
  KHAO_SAT      KHAO_SAT[]     @relation("NGUOI_KHAO_SAT")

  @@index([IS_ACTIVE, ROLE])
  @@fulltext([HO_TEN, USER_NAME, MA_NV])
  @@map("DSNV")
}

enum ROLE {
  ADMIN
  MANAGER
  STAFF
}

// ===== DANH MỤC HÀNG HÓA (Product Catalog) =====
model DMHH {
  ID      String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_HH   String  @unique
  NHOM_HH String? // Nhóm hàng (text, không bắt buộc)

  MA_PHAN_LOAI  String?
  PHAN_LOAI_REL PHANLOAI_HH? @relation(fields: [MA_PHAN_LOAI], references: [MA_PHAN_LOAI])

  MA_DONG_HANG  String?
  DONG_HANG_REL DONG_HH? @relation(fields: [MA_DONG_HANG], references: [MA_DONG_HANG])

  TEN_HH      String
  MODEL       String?
  MO_TA       String?
  DON_VI_TINH String
  HINH_ANH    String?
  XUAT_XU     String?
  BAO_HANH    String?
  HIEU_LUC    Boolean @default(true)

  GIA_BANS    GIA_BAN[] // Relation ngược từ GIA_BAN
  GIA_NHAPS   GIA_NHAP[] // Relation ngược từ GIA_NHAP
  BAO_GIA_CTS BAO_GIA_CT[] // Relation ngược từ BAO_GIA_CT

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([NHOM_HH, MA_PHAN_LOAI, MA_DONG_HANG])
  @@fulltext([TEN_HH, MODEL, MA_HH])
  @@map("DMHH")
}

// ===== PHÂN LOẠI HÀNG HÓA =====
model PHANLOAI_HH {
  ID            String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_PHAN_LOAI  String  @unique
  TEN_PHAN_LOAI String
  DVT_NHOM      String
  NHOM          String?

  DONG_HHS  DONG_HH[] // Relation to DONG_HH
  GIA_BANS  GIA_BAN[] // Relation ngược từ GIA_BAN
  GIA_NHAPS GIA_NHAP[] // Relation ngược từ GIA_NHAP
  DMHHS     DMHH[] // Relation ngược từ DMHH

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("PHANLOAI_HH")
}

// ===== DÒNG HÀNG HÓA =====
model DONG_HH {
  ID            String      @id @default(auto()) @map("_id") @db.ObjectId
  MA_PHAN_LOAI  String
  PHAN_LOAI     PHANLOAI_HH @relation(fields: [MA_PHAN_LOAI], references: [MA_PHAN_LOAI])
  MA_DONG_HANG  String      @unique // ID dòng hàng
  TEN_DONG_HANG String // Dòng hàng
  TIEN_TO       String? // Tiền tố tên
  HANG          String? // Hãng
  XUAT_XU       String? // Xuất xứ
  DVT           String? // ĐVT

  GIA_BANS  GIA_BAN[] // Relation ngược từ GIA_BAN
  GIA_NHAPS GIA_NHAP[] // Relation ngược từ GIA_NHAP
  GOI_GIAS  GOI_GIA[] // Relation ngược từ GOI_GIA
  DMHHS     DMHH[] // Relation ngược từ DMHH

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_PHAN_LOAI])
  @@map("DONG_HH")
}

// ===== NHÓM HÀNG HÓA =====
model NHOM_HH {
  ID       String @id @default(auto()) @map("_id") @db.ObjectId
  MA_NHOM  String @unique
  TEN_NHOM String

  GIA_BANS  GIA_BAN[] // Relation ngược từ GIA_BAN
  GIA_NHAPS GIA_NHAP[] // Relation ngược từ GIA_NHAP

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NHOM_HH")
}

// ===== PHÂN QUYỀN (Permissions) =====
model PHAN_QUYEN {
  ID         String  @id @default(auto()) @map("_id") @db.ObjectId
  NV_ID      String  @db.ObjectId
  NV         DSNV    @relation(fields: [NV_ID], references: [ID])
  MODULE     String // e.g. "nhan-vien", "hang-hoa", "settings"
  CAN_VIEW   Boolean @default(false)
  CAN_ADD    Boolean @default(false)
  CAN_EDIT   Boolean @default(false)
  CAN_DELETE Boolean @default(false)
  CAN_MANAGE Boolean @default(false) // Toàn quyền

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@unique([NV_ID, MODULE])
  @@index([NV_ID])
  @@map("PHAN_QUYEN")
}

// ===== AUDIT LOG =====
model AUDIT_LOG {
  ID           String   @id @default(auto()) @map("_id") @db.ObjectId
  ACTION       String
  USER_ID      String   @db.ObjectId
  USER         DSNV     @relation(fields: [USER_ID], references: [ID])
  USER_NAME    String? // Denormalize
  TARGET_MODEL String?
  TARGET_ID    String?
  DETAILS      String
  OLD_VALUE    Json?
  NEW_VALUE    Json?
  CREATED_AT   DateTime @default(now())

  @@index([USER_ID, CREATED_AT(sort: Desc)])
  @@index([TARGET_MODEL, TARGET_ID, CREATED_AT(sort: Desc)])
  @@index([CREATED_AT])
  @@map("AUDIT_LOGS")
}

// ===== TỪ ĐIỂN CHỨC VỤ =====
model CD_CHUCVU {
  ID        String  @id @default(auto()) @map("_id") @db.ObjectId
  CHUC_VU   String  @unique
  GHI_CHU   String?
  IS_ACTIVE Boolean @default(true)

  DSNVS DSNV[] // Relation ngược

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("CD_CHUCVU")
}

// ===== TỪ ĐIỂN PHÒNG BAN =====
model CD_PHONGBAN {
  ID        String  @id @default(auto()) @map("_id") @db.ObjectId
  PHONG_BAN String  @unique
  GHI_CHU   String?
  IS_ACTIVE Boolean @default(true)

  DSNVS DSNV[] // Relation ngược

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("CD_PHONGBAN")
}

// ===== PHÂN LOẠI KHÁCH HÀNG =====
model PHANLOAI_KH {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  PL_KH String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("PHANLOAI_KH")
}

// ===== NGUỒN KHÁCH HÀNG =====
model NGUON_KH {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  NGUON String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NGUON_KH")
}

// ===== NHÓM KHÁCH HÀNG =====
model NHOM_KH {
  ID   String @id @default(auto()) @map("_id") @db.ObjectId
  NHOM String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NHOM_KH")
}

// ===== KHÁCH HÀNG TIỀM NĂNG =====
model KHTN {
  ID             String    @id @default(auto()) @map("_id") @db.ObjectId
  MA_KH          String    @unique //KHTN-TEN_VT-XXX
  NHOM_KH        String? //NHOM_KH.NHOM
  NGAY_GHI_NHAN  DateTime?
  TEN_KH         String
  TEN_VT         String?
  HINH_ANH       String?
  DIEN_THOAI     String?
  EMAIL          String?
  MST            String?
  NGAY_THANH_LAP DateTime?
  DIA_CHI        String?
  NGUON          String? //NGUON_KH.NGUON

  MA_NGT               String? //NGUOI_GIOI_THIEU.MA_NGT
  NGUOI_GIOI_THIEU_REL NGUOI_GIOI_THIEU? @relation(fields: [MA_NGT], references: [MA_NGT])

  SALES_PT     String? //DSNV.MA_NV
  SALES_PT_REL DSNV?   @relation("SALES_PT", fields: [SALES_PT], references: [MA_NV])

  PHAN_LOAI String? //PHANLOAI_KH.PL_KH

  NV_CS     String? //DSNV.MA_NV
  NV_CS_REL DSNV?   @relation("NV_CS", fields: [NV_CS], references: [MA_NV])

  LICH_SU       String?
  LY_DO_TU_CHOI String? //LY_DO_TU_CHOI.LY_DO
  LAT           Float?
  LONG          Float?

  NGUOI_DAI_DIEN NGUOI_DAI_DIEN[]
  NGUOI_LIENHE   NGUOI_LIENHE[]
  CO_HOI         CO_HOI[]
  KEHOACH_CSKH   KEHOACH_CSKH[]
  BAO_GIAS       BAO_GIA[]
  KHAO_SAT       KHAO_SAT[]

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([NHOM_KH, PHAN_LOAI])
  @@fulltext([TEN_KH, DIEN_THOAI])
  @@map("KHTN")
}

// ===== NGƯỜI GIỚI THIỆU =====
model NGUOI_GIOI_THIEU {
  ID        String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_NGT    String  @unique //NGT-YYMMDD-XXX
  TEN_NGT   String
  SO_DT_NGT String?

  KHTN KHTN[]

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("NGUOI_GIOI_THIEU")
}

// ===== NGƯỜI ĐẠI DIỆN =====
model NGUOI_DAI_DIEN {
  ID String @id @default(auto()) @map("_id") @db.ObjectId

  MA_KH  String //KHTN.MA_KH
  KH_REL KHTN   @relation(fields: [MA_KH], references: [MA_KH], onDelete: Cascade)

  NGUOI_DD  String
  CHUC_VU   String?
  SDT       String?
  EMAIL     String?
  NGAY_SINH DateTime?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_KH])
  @@map("NGUOI_DAI_DIEN")
}

// ===== NGƯỜI LIÊN HỆ =====
model NGUOI_LIENHE {
  ID     String @id @default(auto()) @map("_id") @db.ObjectId
  MA_NLH String @unique //NLH-YYMMDD-XXX

  MA_KH  String //KHTN.MA_KH
  KH_REL KHTN   @relation(fields: [MA_KH], references: [MA_KH], onDelete: Cascade)

  TENNGUOI_LIENHE String
  CHUC_VU         String?
  SDT             String?
  EMAIL           String?
  GHI_CHU         String?
  HIEU_LUC        String  @default("Đang hiệu lực")

  KEHOACH_CSKH KEHOACH_CSKH[]
  KHAO_SAT     KHAO_SAT[]

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_KH])
  @@map("NGUOI_LIENHE")
}

// ===== GÓI GIÁ (Price Package) =====
model GOI_GIA {
  ID            String  @id @default(auto()) @map("_id") @db.ObjectId
  ID_GOI_GIA    String  @unique
  HIEU_LUC      Boolean @default(true)
  MA_DONG_HANG  String
  DONG_HANG_REL DONG_HH @relation(fields: [MA_DONG_HANG], references: [MA_DONG_HANG])
  GOI_GIA       String
  SL_MIN        Int?
  SL_MAX        Int?

  GIA_BANS GIA_BAN[] // Relation ngược từ GIA_BAN

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_DONG_HANG])
  @@map("GOI_GIA")
}

// ===== NHÀ CUNG CẤP (Supplier) =====
model NCC {
  ID                 String    @id @default(auto()) @map("_id") @db.ObjectId
  MA_NCC             String    @unique
  TEN_VIET_TAT       String?
  TEN_NCC            String
  NGAY_GHI_NHAN      DateTime?
  HINH_ANH           String?
  DIEN_THOAI         String?
  EMAIL_CONG_TY      String?
  MST                String?
  NGAY_THANH_LAP     DateTime?
  DIA_CHI            String?
  NGUOI_DAI_DIEN     String?
  SDT_NGUOI_DAI_DIEN String?

  GIA_NHAPS GIA_NHAP[] // Relation ngược từ GIA_NHAP

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@fulltext([TEN_NCC, MA_NCC, DIEN_THOAI])
  @@map("NCC")
}

// ===== GIÁ NHẬP (Purchase Price) =====
model GIA_NHAP {
  ID            String   @id @default(auto()) @map("_id") @db.ObjectId
  NGAY_HIEU_LUC DateTime

  // --- Các cột liên kết (giống GIA_BAN) ---
  MA_NHOM_HH String
  NHOM_GN    NHOM_HH? @relation(fields: [MA_NHOM_HH], references: [MA_NHOM])

  MA_PHAN_LOAI String
  PHAN_LOAI_GN PHANLOAI_HH? @relation(fields: [MA_PHAN_LOAI], references: [MA_PHAN_LOAI])

  MA_DONG_HANG String
  DONG_HANG_GN DONG_HH? @relation(fields: [MA_DONG_HANG], references: [MA_DONG_HANG])

  MA_NCC  String
  NCC_REL NCC?   @relation(fields: [MA_NCC], references: [MA_NCC])

  MA_HH  String
  HH_REL DMHH?  @relation(fields: [MA_HH], references: [MA_HH])

  // --- Các cột dữ liệu ---
  DON_GIA Float

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_NHOM_HH, MA_PHAN_LOAI, MA_DONG_HANG])
  @@index([MA_NCC, MA_HH])
  @@fulltext([MA_NCC, MA_HH, MA_NHOM_HH])
  @@map("GIA_NHAP")
}

// ===== LÝ DO TỪ CHỐI =====
model LY_DO_TU_CHOI {
  ID    String @id @default(auto()) @map("_id") @db.ObjectId
  LY_DO String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("LY_DO_TU_CHOI")
}

// ===== DANH MỤC DỊCH VỤ (Service Catalog) =====
model DM_DICH_VU {
  ID         String @id @default(auto()) @map("_id") @db.ObjectId
  MA_DV      String @unique
  NHOM_DV    String // Nhóm dịch vụ
  DICH_VU    String // Tên dịch vụ
  GIA_TRI_TB Float // Giá trị trung bình

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([NHOM_DV])
  @@map("DM_DICH_VU")
}

// ===== CƠ HỘI (Opportunity) =====
model CO_HOI {
  ID       String   @id @default(auto()) @map("_id") @db.ObjectId
  MA_CH    String   @unique // OP-TEN_VT-YYMMDD-001
  NGAY_TAO DateTime @default(now())

  MA_KH  String
  KH_REL KHTN   @relation(fields: [MA_KH], references: [MA_KH])

  NHU_CAU         Json? // Mảng các DM_DICH_VU.MA_DV được chọn
  GHI_CHU_NC      String?
  GIA_TRI_DU_KIEN Float?
  NGAY_DK_CHOT    DateTime?
  TINH_TRANG      String    @default("Đang mở")
  NGAY_DONG       DateTime?
  LY_DO           String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  KEHOACH_CSKH KEHOACH_CSKH[]
  BAO_GIAS     BAO_GIA[]
  KHAO_SAT     KHAO_SAT[]

  @@index([MA_KH])
  @@index([TINH_TRANG])
  @@map("CO_HOI")
}

// ===== GIÁ BÁN (Selling Price) =====
model GIA_BAN {
  ID            String   @id @default(auto()) @map("_id") @db.ObjectId
  NGAY_HIEU_LUC DateTime

  // --- Các cột liên kết (lưu mã, dùng @relation để lấy tên) ---
  MA_NHOM_HH String
  NHOM       NHOM_HH? @relation(fields: [MA_NHOM_HH], references: [MA_NHOM])

  MA_PHAN_LOAI  String
  PHAN_LOAI_REL PHANLOAI_HH? @relation(fields: [MA_PHAN_LOAI], references: [MA_PHAN_LOAI])

  MA_DONG_HANG  String
  DONG_HANG_REL DONG_HH? @relation(fields: [MA_DONG_HANG], references: [MA_DONG_HANG])

  MA_GOI_GIA  String
  GOI_GIA_REL GOI_GIA? @relation(fields: [MA_GOI_GIA], references: [ID_GOI_GIA])

  MA_HH    String
  HANG_HOA DMHH?  @relation(fields: [MA_HH], references: [MA_HH])

  // --- Các cột dữ liệu ---
  DON_GIA Float
  GHI_CHU String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_NHOM_HH, MA_PHAN_LOAI, MA_DONG_HANG])
  @@index([MA_HH])
  @@fulltext([MA_HH, MA_NHOM_HH, MA_GOI_GIA])
  @@map("GIA_BAN")
}

// ===== LOẠI CHĂM SÓC (Care Type) =====
model LOAI_CHAM_SOC {
  ID      String @id @default(auto()) @map("_id") @db.ObjectId
  LOAI_CS String @unique

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("LOAI_CHAM_SOC")
}

// ===== KẾT QUẢ CHĂM SÓC (Care Result) =====
model KET_QUA_CS {
  ID    String  @id @default(auto()) @map("_id") @db.ObjectId
  KQ_CS String  @unique
  XL_CS String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("KET_QUA_CS")
}

// ===== KẾ HOẠCH CHĂM SÓC KHÁCH HÀNG =====
model KEHOACH_CSKH {
  ID     String @id @default(auto()) @map("_id") @db.ObjectId
  MA_KH  String //KHTN.MA_KH
  KH_REL KHTN   @relation(fields: [MA_KH], references: [MA_KH])

  MA_NLH  String? // Người liên hệ (NGUOI_LIENHE.MA_NLH)
  NLH_REL NGUOI_LIENHE? @relation(fields: [MA_NLH], references: [MA_NLH])

  MA_CH      String? // Cơ hội (CO_HOI.MA_CH)
  CO_HOI_REL CO_HOI? @relation(fields: [MA_CH], references: [MA_CH])

  LOAI_CS   String?
  TG_TU     DateTime? // Thời gian từ
  TG_DEN    DateTime? // Thời gian đến
  HINH_THUC String? // Online / Trực tiếp
  DIA_DIEM  String?

  NGUOI_CS     String? // Người chăm sóc (DSNV.MA_NV)
  NGUOI_CS_REL DSNV?   @relation("NGUOI_CS", fields: [NGUOI_CS], references: [MA_NV])

  NGAY_CS_TT  DateTime? // Ngày chăm sóc thực tế
  HINH_ANH    String?
  FILE        String?
  LINK_BC     String? // Link báo cáo
  DICH_VU_QT  Json? // Dịch vụ quan tâm (mảng DM_DICH_VU.MA_DV)
  KQ_CS       String? //kết quả cs (KET_QUA_CS.KQ_CS)
  XL_CS       String? // Xếp loại chăm sóc (KET_QUA_CS.XL_CS)
  NOI_DUNG_TD String? // Nội dung trao đổi
  LY_DO_TC    String? // LY_DO_TU_CHOI.LY_DO
  GHI_CHU_NC  String? // Ghi chú nội bộ
  TRANG_THAI  String    @default("Chờ báo cáo")

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_KH])
  @@index([TRANG_THAI])
  @@map("KEHOACH_CSKH")
}

// ===== CÀI ĐẶT LOẠI CÔNG TRÌNH =====
model CD_LOAI_CONG_TRINH {
  ID              String @id @default(auto()) @map("_id") @db.ObjectId
  LOAI_CONG_TRINH String @unique
  STT             Int    @default(0)

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("CD_LOAI_CONG_TRINH")
}

// ===== CÀI ĐẶT NHÓM KHẢO SÁT =====
model CD_NHOM_KS {
  ID      String @id @default(auto()) @map("_id") @db.ObjectId
  NHOM_KS String @unique
  STT     Int    @default(0)

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@map("CD_NHOM_KS")
}

// ===== HẠNG MỤC KHẢO SÁT =====
model HANG_MUC_KS {
  ID              String  @id @default(auto()) @map("_id") @db.ObjectId
  MA_HMKS         String  @unique
  LOAI_CONG_TRINH String
  NHOM_KS         String
  HANG_MUC_KS     String
  HIEU_LUC        Boolean @default(true)
  STT             Int     @default(0)

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([LOAI_CONG_TRINH, NHOM_KS])
  @@fulltext([LOAI_CONG_TRINH, NHOM_KS, HANG_MUC_KS])
  @@map("HANG_MUC_KS")
}

// ===== BÁO GIÁ (Quotation Header) =====
model BAO_GIA {
  ID         String @id @default(auto()) @map("_id") @db.ObjectId
  MA_BAO_GIA String @unique // BG-YYMMDD-001

  NGAY_BAO_GIA DateTime @default(now())

  // Khách hàng — lưu MA_KH, relation sang KHTN
  MA_KH  String
  KH_REL KHTN   @relation(fields: [MA_KH], references: [MA_KH])

  // Cơ hội — lưu MA_CH, relation sang CO_HOI (optional)
  MA_CH      String?
  CO_HOI_REL CO_HOI? @relation(fields: [MA_CH], references: [MA_CH])

  LOAI_BAO_GIA String @default("Dân dụng") // "Dân dụng" | "Công nghiệp"

  // Tài chính — tổng hợp từ chi tiết
  TT_TRUOC_UU_DAI Float @default(0)
  PT_UU_DAI       Float @default(0) // % ưu đãi chung
  TT_UU_DAI       Float @default(0)
  TT_SAU_UU_DAI   Float @default(0)
  PT_VAT          Float @default(0) // % VAT chung
  TT_VAT          Float @default(0)
  TONG_TIEN       Float @default(0)

  GHI_CHU           String?
  THOI_GIAN_LAP_DAT String?
  TEP_DINH_KEM      String[] // Mảng URL tệp đính kèm (ảnh, PDF, Word...)

  CHI_TIETS BAO_GIA_CT[] // 1-N relation
  DKTT_BG   DKTT_BG[] // 1-N relation: điều kiện thanh toán

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_KH])
  @@index([MA_CH])
  @@fulltext([MA_BAO_GIA, MA_KH])
  @@map("BAO_GIA")
}

// ===== ĐIỀU KIỆN THANH TOÁN BÁO GIÁ =====
model DKTT_BG {
  ID String @id @default(auto()) @map("_id") @db.ObjectId

  MA_BAO_GIA  String
  BAO_GIA_REL BAO_GIA @relation(fields: [MA_BAO_GIA], references: [MA_BAO_GIA], onDelete: Cascade)

  DOT_THANH_TOAN   String // Đợt 1, Đợt 2...
  PT_THANH_TOAN    Float   @default(0) // % thanh toán
  NOI_DUNG_YEU_CAU String? // Nội dung yêu cầu

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_BAO_GIA])
  @@map("DKTT_BG")
}

// ===== BÁO GIÁ CHI TIẾT (Quotation Detail) =====
model BAO_GIA_CT {
  ID String @id @default(auto()) @map("_id") @db.ObjectId

  MA_BAO_GIA  String
  BAO_GIA_REL BAO_GIA @relation(fields: [MA_BAO_GIA], references: [MA_BAO_GIA], onDelete: Cascade)

  // Hàng hóa — lưu MA_HH, relation sang DMHH
  MA_HH  String
  HH_REL DMHH   @relation(fields: [MA_HH], references: [MA_HH])

  DON_VI_TINH String
  GIA_BAN     Float  @default(0)
  SO_LUONG    Float  @default(1)
  THANH_TIEN  Float  @default(0)

  PT_UU_DAI       Float @default(0)
  TIEN_UU_DAI     Float @default(0)
  TIEN_SAU_UU_DAI Float @default(0)

  PT_VAT    Float @default(0)
  TIEN_VAT  Float @default(0)
  TONG_TIEN Float @default(0)

  GHI_CHU String?

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_BAO_GIA])
  @@index([MA_HH])
  @@map("BAO_GIA_CT")
}

// ===== HÌNH ẢNH KHẢO SÁT =====
type HINH_ANH_KS {
  TEN_HINH String
  URL_HINH String
}

// ===== KHẢO SÁT CÔNG TRÌNH =====
model KHAO_SAT {
  ID            String   @id @default(auto()) @map("_id") @db.ObjectId
  MA_KHAO_SAT   String   @unique
  NGAY_KHAO_SAT DateTime @default(now())

  NGUOI_KHAO_SAT     String?
  NGUOI_KHAO_SAT_REL DSNV?   @relation("NGUOI_KHAO_SAT", fields: [NGUOI_KHAO_SAT], references: [MA_NV])

  MA_KH    String?
  KHTN_REL KHTN?   @relation(fields: [MA_KH], references: [MA_KH])

  MA_CH      String?
  CO_HOI_REL CO_HOI? @relation(fields: [MA_CH], references: [MA_CH])

  DIA_CHI           String?
  NGUOI_LIEN_HE     String?
  NGUOI_LIEN_HE_REL NGUOI_LIENHE? @relation(fields: [NGUOI_LIEN_HE], references: [MA_NLH])

  DIA_CHI_CONG_TRINH String?
  LOAI_CONG_TRINH    String
  HINH_ANH           HINH_ANH_KS[]

  KHAO_SAT_CT KHAO_SAT_CT[]

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_KH, MA_CH])
  @@fulltext([MA_KHAO_SAT, MA_KH, MA_CH, DIA_CHI, DIA_CHI_CONG_TRINH, LOAI_CONG_TRINH])
  @@map("KHAO_SAT")
}

// ===== KHẢO SÁT CHI TIẾT =====
model KHAO_SAT_CT {
  ID String @id @default(auto()) @map("_id") @db.ObjectId

  MA_KHAO_SAT  String
  KHAO_SAT_REL KHAO_SAT @relation(fields: [MA_KHAO_SAT], references: [MA_KHAO_SAT], onDelete: Cascade)

  NHOM_KS      String
  HANG_MUC_KS  String
  CHI_TIET     String
  STT_NHOM_KS  Int    @default(0)
  STT_HANG_MUC Int    @default(0)

  CREATED_AT DateTime @default(now())
  UPDATED_AT DateTime @updatedAt

  @@index([MA_KHAO_SAT])
  @@index([NHOM_KS, HANG_MUC_KS, STT_NHOM_KS, STT_HANG_MUC])
  @@map("KHAO_SAT_CT")
}
